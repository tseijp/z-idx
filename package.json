{
        "name": "z-idx",
        "version": "1.0.0",
        "license": "MIT",
        "private": false,
        "sideEffect": false,
        "type": "module",
        "publishConfig": {
                "access": "public"
        },
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "module": "./dist/index.mjs",
        "exports": {
                ".": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "require": "./dist/index.js",
                        "default": "./dist/index.mjs"
                },
                "./*": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "require": "./dist/index.js",
                        "default": "./dist/index.mjs"
                }
        },
        "files": [
                "dist/**/*",
                "README.md"
        ],
        "scripts": {
                "dev": "vite",
                "build": "npx tsup",
                "preview": "vite preview",
                "pub": "npx changeset publish",
                "test": "npx vitest run --coverage"
        },
        "devDependencies": {
                "@changesets/cli": "*",
                "@vitest/coverage-v8": "*",
                "tsup": "*",
                "typescript": "~5.9.3",
                "vite": "*",
                "vitest": "*"
        }
}
